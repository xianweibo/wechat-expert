# ============================================
# 公众号专家 - 环境变量模板
# 复制为 .env 后填入真实值
# ============================================

# --- 运行环境 ---
NODE_ENV=production
PORT=3000

# --- 数据库 (PostgreSQL) ---
POSTGRES_USER=gzh_expert
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=gzh_expert
DATABASE_URL=postgresql://gzh_expert:CHANGE_ME_STRONG_PASSWORD@postgres:5432/gzh_expert

# --- 微信公众号 ---
WECHAT_APP_ID=wx567a639466e247cd
WECHAT_APP_SECRET=你的AppSecret

# --- B站 Worker 推送 Secret (NAS 用这个来认证) ---
BILIBILI_WORKER_SECRET=CHANGE_ME_RANDOM_SECRET

# --- 微信小程序 ---
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=

# --- 小程序广告 (激励视频) ---
MINIPROGRAM_AD_UNIT_ID=
AD_MODE=mock

# --- 公众号草稿模式: manual(手动复制) | api(自动创建草稿) ---
WECHAT_MP_DRAFT_MODE=api

# --- AI 服务 (未使用) ---
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# --- JWT / Session ---
JWT_SECRET=CHANGE_ME_RANDOM_STRING_32_CHARS_MIN

# --- 服务器配置 ---
SERVER_HOST=8.134.248.11
DOMAIN=
# ---- Cover image generation (MiniMax image_generation API) ----
# Set to true to generate per-article cover via MiniMax. When false, falls
# back to the fixed COVER_IMAGE_URL above.
COVER_GEN_ENABLED=false
# API key for image generation. If unset, falls back to MINIMAX_API_KEY.
MINIMAX_IMAGE_API_KEY=
MINIMAX_IMAGE_MODEL=image-01
COVER_ASPECT_RATIO=16:9
# Local directory where generated covers are saved before WeChat upload.
COVERS_DIR=./covers