# --- å°ç¨‹åºå¹¿å‘Š (æ¿€åŠ±è§†é¢‘) ---
MINIPROGRAM_AD_UNIT_ID=
AD_MODE=mock

# --- å…¬ä¼—å·è‰ç¨¿æ¨¡å¼: manual(æ‰‹åŠ¨å¤åˆ¶) | api(è‡ªåŠ¨åˆ›å»ºè‰ç¨¿) ---
WECHAT_MP_DRAFT_MODE=api

# --- AI æœåŠ¡ (æœªä½¿ç”¨) ---
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# --- JWT / Session ---
JWT_SECRET=CHANGE_ME_RANDOM_STRING_32_CHARS_MIN

# --- æœåŠ¡å™¨é…ç½® ---
SERVER_HOST=8.134.248.11
DOMAIN=

# ---- Cover image generation (MiniMax image_generation API) ----
# Set to true to generate per-article cover via MiniMax. When false, falls
# back to the fixed COVER_IMAGE_URL above.
COVER_GEN_ENABLED=false

# API key for image generation. Usually the SAME as MINIMAX_API_KEY above.
# Leave blank to reuse MINIMAX_API_KEY automatically.
MINIMAX_IMAGE_API_KEY=
MINIMAX_IMAGE_MODEL=image-01

# Aspect ratio for generated covers. WeChat list-card native ratio is 2.35:1,
# but the generator supports: 1:1, 16:9, 2.35:1, 4:3, 3:4.
COVER_ASPECT_RATIO=16:9

# Visual style preset for cover generation. One of:
#   auto       - generic professional editorial (default)
#   tech       - AI / programming / software topics
#   finance    - stocks / economy / markets topics
#   lifestyle  - personal growth / wellness topics
#   education  - learning / knowledge / tutorial topics
#   news       - current events / breaking news topics
# The style can also be overridden per-request via the cover.style field.
COVER_STYLE=auto

# Whether to render the article title on the cover image as text overlay.
# When true (default), the title is rendered in elegant typography.
COVER_TEXT_OVERLAY=true

# Retry settings for transient failures (5xx / 429 / network).
# Total attempts = COVER_RETRY_MAX + 1. Exponential backoff base ms.
COVER_RETRY_MAX=2
COVER_RETRY_BASE_MS=1500

# Local directory where generated covers are saved before WeChat upload.
COVERS_DIR=./covers