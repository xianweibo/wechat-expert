# ============================================
# 公众号专家 - 环境变量模板
# 复制为 .env 后填入真实值
# ============================================

# --- 运行环境 ---
NODE_ENV=production
PORT=3000

# --- 数据库 (PostgreSQL) ---
POSTGRES_USER=gzh_expert
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=gzh_expert
DATABASE_URL=postgresql://gzh_expert:CHANGE_ME_STRONG_PASSWORD@postgres:5432/gzh_expert

# --- 微信公众号 ---
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=

# --- 微信小程序 ---
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=

# --- 小程序广告 (激励视频) ---
MINIPROGRAM_AD_UNIT_ID=
AD_MODE=mock

# --- 公众号草稿模式: manual(手动复制) | api(自动创建草稿) ---
WECHAT_MP_DRAFT_MODE=manual

# --- AI 服务 ---
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# --- JWT / Session ---
JWT_SECRET=CHANGE_ME_RANDOM_STRING_32_CHARS_MIN

# --- 服务器配置 ---
SERVER_HOST=8.134.248.11
DOMAIN=

# --- 腾讯 IMA (后续接入) ---
IMA_API_KEY=
IMA_KB_ID=
